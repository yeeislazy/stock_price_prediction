{
    "features":{
        "base_features": ["open", "high", "low", "close", "volume", "year", "month", "day"],
        "extra_features": [ "ma20", "rsi14", "ATR" ]
    },
    "targets": {
        "columns": ["return_2", "return_5", "return_14"],
        "weight_decay": [0.7, 0.8, 0.9]
    },
    "model": {
            "name": "LSTMModel",
            "input_size": 8,
            "output_size": 3,
            "projection_size": [32, 64, 128],
            "hidden_size": [64, 128, 256],
            "num_layers": [2, 3, 4],
            "seq_len": [30, 60],
            "num_epochs": 100,
            "lr": [1e-4 , 1e-3]
    }
}